# Frontend (Vite) — copie para .env e preencha com os dados do seu projeto Supabase
VITE_SUPABASE_URL=https://SEU-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key

# --------------------------------------------------------------------------
# Os tokens abaixo NÃO vão no .env do frontend.
# Configure-os como Secrets das Edge Functions no Supabase:
#   supabase secrets set KOMMO_TOKEN=... KOMMO_SUBDOMAIN=zeandre CLICKUP_TOKEN=...
#
#   KOMMO_TOKEN       — token de longa duração da API do Kommo
#   KOMMO_SUBDOMAIN   — subdomínio da conta Kommo (ex.: zeandre)
#   CLICKUP_TOKEN     — token pessoal da API do ClickUp (pk_...)
# --------------------------------------------------------------------------
